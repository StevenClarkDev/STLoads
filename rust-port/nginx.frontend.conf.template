server {
    listen 8080;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    proxy_http_version 1.1;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), payment=(), usb=(), geolocation=(self)" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://maps.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: blob: https://*.googleapis.com https://*.gstatic.com https://*.googleusercontent.com https://www.openstreetmap.org; connect-src 'self' ${BACKEND_UPSTREAM} https://api.stripe.com https://maps.googleapis.com https://*.googleapis.com wss:; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://www.openstreetmap.org; worker-src 'self' blob:; upgrade-insecure-requests" always;

    location = /health {
        access_log off;
        default_type application/json;
        return 200 '{"service":"stloads-frontend","status":"ok"}';
    }

    location = /index.html {
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), payment=(), usb=(), geolocation=(self)" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://maps.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: blob: https://*.googleapis.com https://*.gstatic.com https://*.googleusercontent.com https://www.openstreetmap.org; connect-src 'self' ${BACKEND_UPSTREAM} https://api.stripe.com https://maps.googleapis.com https://*.googleapis.com wss:; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://www.openstreetmap.org; worker-src 'self' blob:; upgrade-insecure-requests" always;
        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        try_files /index.html =404;
    }

    location = /runtime-config.js {
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), payment=(), usb=(), geolocation=(self)" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://maps.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: blob: https://*.googleapis.com https://*.gstatic.com https://*.googleusercontent.com https://www.openstreetmap.org; connect-src 'self' ${BACKEND_UPSTREAM} https://api.stripe.com https://maps.googleapis.com https://*.googleapis.com wss:; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://www.openstreetmap.org; worker-src 'self' blob:; upgrade-insecure-requests" always;
        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        try_files /runtime-config.js =404;
    }

    location @backend_api {
        proxy_set_header Host $proxy_host;
        proxy_pass ${BACKEND_UPSTREAM};
    }

    location ~ ^/(auth|dispatch|marketplace|execution|payments|tms|admin|master-data)(/|$) {
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), payment=(), usb=(), geolocation=(self)" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://maps.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: blob: https://*.googleapis.com https://*.gstatic.com https://*.googleusercontent.com https://www.openstreetmap.org; connect-src 'self' ${BACKEND_UPSTREAM} https://api.stripe.com https://maps.googleapis.com https://*.googleapis.com wss:; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://www.openstreetmap.org; worker-src 'self' blob:; upgrade-insecure-requests" always;
        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        error_page 418 = @backend_api;

        if ($request_method !~ ^(GET|HEAD)$) {
            return 418;
        }

        if ($http_accept !~* "text/html") {
            return 418;
        }

        try_files $uri $uri/ /index.html;
    }

    location /api/stloads/ {
        rewrite ^/api/stloads/(.*)$ /$1 break;
        proxy_set_header Host $proxy_host;
        proxy_pass ${BACKEND_UPSTREAM};
    }

    location /realtime/ {
        proxy_set_header Host $proxy_host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_pass ${BACKEND_UPSTREAM};
    }

    location / {
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), payment=(), usb=(), geolocation=(self)" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://maps.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: blob: https://*.googleapis.com https://*.gstatic.com https://*.googleusercontent.com https://www.openstreetmap.org; connect-src 'self' ${BACKEND_UPSTREAM} https://api.stripe.com https://maps.googleapis.com https://*.googleapis.com wss:; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://www.openstreetmap.org; worker-src 'self' blob:; upgrade-insecure-requests" always;
        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(js|css|wasm|json|svg|png|jpg|jpeg|gif|ico|woff|woff2)$ {
        expires 1h;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), payment=(), usb=(), geolocation=(self)" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://maps.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: blob: https://*.googleapis.com https://*.gstatic.com https://*.googleusercontent.com https://www.openstreetmap.org; connect-src 'self' ${BACKEND_UPSTREAM} https://api.stripe.com https://maps.googleapis.com https://*.googleapis.com wss:; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://www.openstreetmap.org; worker-src 'self' blob:; upgrade-insecure-requests" always;
        add_header Cache-Control "public";
        try_files $uri =404;
    }
}
