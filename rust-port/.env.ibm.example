# IBM Code Engine / IBM PostgreSQL example environment for the Rust STLoads port.
# Copy this to a local runtime file such as `.env.ibm.runtime` before deployment.
# For Code Engine, keep PORT at 8080 unless you explicitly deploy the app with a different --port value.

# Backend runtime
APP_ENV=staging
DEPLOYMENT_TARGET=ibm-code-engine
BIND_ADDR=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=https://stloads-rust-backend.us-south.codeengine.appdomain.cloud
RUN_MIGRATIONS=false
RUST_LOG=backend=info,tower_http=info

# PostgreSQL
# Use the IBM Databases for PostgreSQL connection string here.
# Add sslmode=require unless your service binding already supplies it.
DATABASE_URL=postgres://stloads_user:replace_me@postgres.example.com:5432/stloads_rust?sslmode=require
STLOADS_DATABASE_SCHEMA=stloads

# Document storage
# IBM Cloud Object Storage uses the S3-compatible API in this Rust slice.
DOCUMENT_STORAGE_BACKEND=ibm_cos
DOCUMENT_STORAGE_ROOT=./runtime/document-storage
OBJECT_STORAGE_BUCKET=stloads-documents
OBJECT_STORAGE_REGION=us-south
OBJECT_STORAGE_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
OBJECT_STORAGE_ACCESS_KEY_ID=replace-me
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-me
OBJECT_STORAGE_SESSION_TOKEN=
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_PREFIX=load-documents

# Optional shared-secret webhook auth
STRIPE_SECRET=replace-me
STRIPE_WEBHOOK_SECRET_PLATFORM=replace-me
STRIPE_WEBHOOK_SECRET_CONNECT=replace-me
STRIPE_CONNECT_REFRESH_URL=https://portal.stloads.com/settings/payouts?refresh=1
STRIPE_CONNECT_RETURN_URL=https://portal.stloads.com/settings/payouts?done=1
STRIPE_LIVE_TRANSFERS_REQUIRED=false
TMS_SHARED_SECRET=replace-me
TMS_RETRY_WORKER_ENABLED=true
TMS_RETRY_INTERVAL_SECONDS=300
TMS_RETRY_BATCH_SIZE=10
TMS_RETRY_MAX_ATTEMPTS=5
TMS_RECONCILIATION_WORKER_ENABLED=true
TMS_RECONCILIATION_INTERVAL_SECONDS=21600
TMS_STALE_HANDOFF_DAYS=30

# Outbound email
# Use MAIL_MAILER=log for staging smoke runs, or MAIL_MAILER=smtp with provider secrets in Code Engine.
MAIL_MAILER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-me
MAIL_PASSWORD=replace-me
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@stloads.com
MAIL_FROM_NAME=STLoads
MAIL_FAIL_OPEN=true
MAIL_OUTBOX_ENABLED=true
MAIL_OUTBOX_WORKER_ENABLED=true
MAIL_OUTBOX_BATCH_SIZE=25
MAIL_OUTBOX_RETRY_INTERVAL_SECONDS=30
MAIL_OUTBOX_MAX_ATTEMPTS=8
PORTAL_URL=https://portal.stloads.com

# Frontend runtime / build-time base URL
# Leave empty if the frontend nginx container proxies to BACKEND_UPSTREAM.
BACKEND_API_BASE_URL=
BACKEND_UPSTREAM=https://stloads-rust-backend.us-south.codeengine.appdomain.cloud
FRONTEND_PUBLIC_URL=https://stloads-frontend.us-south.codeengine.appdomain.cloud

# Dispatch -> STLoads handoff integration.
# Set dispatch STLOADS_TMS_SHARED_SECRET to the same value as TMS_SHARED_SECRET above.

# Optional local smoke-test helpers
RUST_TEST_DATABASE_URL=postgres://stloads_test_user:replace_me@postgres.example.com:5432/stloads_rust_test?sslmode=require
STLOADS_AUTH_TOKEN=

# Current disposable smoke users from scripts/seed_postgres_smoke_data.sql
# admin.smoke@stloads.test / AdminPass123!
# shipper.smoke@stloads.test / ShipperPass123!
# carrier.smoke@stloads.test / CarrierPass123!
